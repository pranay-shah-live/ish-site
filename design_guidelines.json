  "instructions_to_main_agent": [
    "INSTALL FONTS: Add the Google Fonts import to your index.css immediately.",
    "THEME: Force Light Mode by default. Do not use dark mode classes unless toggled via the accessibility widget.",
    "ACCESSIBILITY WIDGET: Create this as a global component 'AccessibilityPanel' that lives in the main layout. It should use local storage to persist preferences.",
    "MOTION: Use framer-motion for simple staggered reveals on scroll, but WRAP them in a 'ReducedMotion' check. If user prefers reduced motion, disable all transforms.",
    "FORMS: Use Shadcn Form components but override styles to match the 'Brutalist' input style (thick border, no radius).",
    "CONTRAST: Always verify text contrast. Use Black text on White/Grey backgrounds. Use White text ONLY on deep Primary Blue or Black backgrounds.",
    "SKIP LINK: Implement a 'Skip to Main Content' link as the very first focusable element in the app.",
    "IMAGES: Use 'object-cover' for all images to ensure they fill their brutalist containers without distortion.",
    "TESTING: Add 'data-testid' to every interactive element (buttons, links, inputs)."
  ],
  "universal_guidelines": [
    "Avoid generic centered layouts. Use asymmetry where possible.",
    "Use 2-3x more spacing than typical designs (p-8, p-12).",
    "Never use pure black (#000000) for text paragraphs, use #111827. Use pure black only for borders/headings.",
    "Do not use gradients. Stick to flat, bold colors."
  ]
}