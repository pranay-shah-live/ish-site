{
  "design_system": {
    "identity": {
      "name": "India Signing Hands (ISH) - Redesign",
      "style": "Accessible Neo-Brutalism",
      "vibe": "Bold, Inclusive, Energetic, Unapologetic",
      "core_principles": [
        "Accessibility First (WCAG 2.1 AA+)",
        "High Contrast & Clarity",
        "Motion with Purpose (Respect Reduced Motion)",
        "Gen Z Aesthetic (Raw, Authentic, Bold)"
      ]
    },
    "typography": {
      "font_family": {
        "heading": "Oswald, sans-serif",
        "body": "Lexend, sans-serif"
      },
      "scale": {
        "h1": "text-5xl md:text-7xl font-bold uppercase tracking-tight",
        "h2": "text-4xl md:text-5xl font-bold uppercase",
        "h3": "text-2xl md:text-3xl font-semibold",
        "body": "text-lg md:text-xl leading-relaxed",
        "caption": "text-sm font-medium uppercase tracking-widest"
      },
      "weights": {
        "regular": 400,
        "medium": 500,
        "bold": 700
      },
      "import_url": "https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700&family=Oswald:wght@400;500;700&display=swap"
    },
    "colors": {
      "palette": {
        "primary": "#1A56DB",
        "primary_foreground": "#FFFFFF",
        "secondary": "#FF6B00",
        "secondary_foreground": "#000000",
        "accent": "#FDE047",
        "accent_foreground": "#000000",
        "background": "#FFFFFF",
        "foreground": "#111827",
        "muted": "#F3F4F6",
        "muted_foreground": "#4B5563",
        "border": "#000000",
        "card": "#FFFFFF",
        "card_foreground": "#000000",
        "input": "#E5E7EB",
        "ring": "#000000"
      },
      "usage": {
        "primary_action": "bg-primary text-primary-foreground hover:bg-blue-800",
        "secondary_action": "bg-secondary text-secondary-foreground hover:bg-orange-600",
        "high_contrast_border": "border-2 border-black",
        "focus_ring": "ring-4 ring-yellow-400 ring-offset-2"
      }
    },
    "spacing": {
      "container": "container mx-auto px-4 md:px-6 lg:px-8",
      "section_padding": "py-16 md:py-24 lg:py-32",
      "element_gap": "gap-6 md:gap-8 lg:gap-12"
    },
    "visual_enhancers": {
      "shadows": {
        "brutalist": "shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] hover:-translate-y-0.5 transition-all",
        "brutalist_sm": "shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]"
      },
      "borders": {
        "thick": "border-2 border-black",
        "default": "border border-black"
      },
      "radius": {
        "default": "rounded-sm",
        "pill": "rounded-full",
        "none": "rounded-none"
      }
    }
  },
  "layout_strategies": {
    "grid_system": {
      "bento_grid": "grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 auto-rows-[minmax(300px,auto)]",
      "logo_wall": "flex gap-12 overflow-hidden py-10",
      "team_grid": "grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8"
    },
    "accessibility": {
      "focus_visible": "focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-yellow-400 focus-visible:ring-offset-2",
      "skip_link": "fixed top-4 left-4 z-50 -translate-y-[150%] focus:translate-y-0 bg-black text-white px-6 py-3 font-bold transition-transform",
      "reduced_motion": "motion-reduce:transition-none motion-reduce:animate-none"
    }
  },
  "components": {
    "accessibility_widget": {
      "position": "fixed bottom-6 left-6 z-50",
      "trigger": "w-14 h-14 bg-black text-white rounded-full flex items-center justify-center shadow-brutalist hover:scale-110 transition-transform",
      "panel": "absolute bottom-16 left-0 w-72 bg-white border-2 border-black shadow-brutalist p-6 space-y-4 rounded-sm"
    },
    "buttons": {
      "primary": "inline-flex items-center justify-center whitespace-nowrap text-lg font-bold uppercase tracking-wide bg-primary text-white border-2 border-black shadow-brutalist hover:translate-y-[2px] hover:shadow-none transition-all px-8 py-4",
      "secondary": "inline-flex items-center justify-center whitespace-nowrap text-lg font-bold uppercase tracking-wide bg-white text-black border-2 border-black shadow-brutalist hover:bg-gray-100 transition-all px-8 py-4"
    },
    "cards": {
      "service_card": "group relative overflow-hidden bg-white border-2 border-black shadow-brutalist hover:shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] transition-all p-8 flex flex-col justify-between h-full",
      "team_card": "bg-white border-2 border-black p-4 text-center space-y-3"
    }
  },
